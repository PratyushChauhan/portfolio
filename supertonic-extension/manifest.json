{
  "manifest_version": 3,
  "name": "Supertonic Narrator",
  "short_name": "STNarrator",
  "version": "2.0.0",
  "description": "On-device Supertonic TTS narration. v2 runs ONNX models locally via ts-voice.",
  "permissions": [
    "activeTab",
    "storage",
    "offscreen"
  ],
  "host_permissions": [
    "https://unpkg.com/*",
    "https://cdn.jsdelivr.net/*",
    "https://huggingface.co/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "css": ["content.css"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "content_security_policy": {
    "extension_pages": "script-src 'self' https://unpkg.com https://cdn.jsdelivr.net; object-src 'self'; connect-src 'self' https://unpkg.com https://cdn.jsdelivr.net https://huggingface.co"
  }
}
